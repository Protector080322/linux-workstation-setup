# AI Provider API Key
ANTHROPIC_API_KEY=your_api_key_here

# Optional OpenAI Support
OPENAI_API_KEY=your_api_key_here

# Scan Configuration
SCAN_MODE=full

# Report Settings
ENABLE_JSON_REPORTS=true
ENABLE_TXT_REPORTS=true

# Monitoring
ENABLE_LIVE_MONITORING=true

# Docker Integration
ENABLE_DOCKER_CHECKS=true

# Logging
LOG_LEVEL=INFO
